#!/usr/bin/env python3
"""ongo-poll — robust Slack poll for the ongo tick loop.

Usage:
    ongo-poll <CHANNEL> <LAST_USER_TS>

Prints JSON:
    {
      "total_seen":     <int>,    # all messages gathered this poll
      "user_count":     <int>,    # NEW user (non-[ongo]) messages
      "newest_user_ts": "<str>",  # max ts among returned user msgs,
                                  #   else LAST_USER_TS unchanged
      "user_messages":  [ {"ts","text"}, ... ]   # ascending, ts > LAST_USER_TS
    }

WHY THIS EXISTS — two bugs, fixed in two stages
------------------------------------------------
Stage 1 (original deaf-loop bug): `clacks read --after $ts` returns a
bounded oldest-first slice anchored at `ts`, not a stream since `ts`.
With the cursor frozen at session start it returned only old bot
chatter; real user messages further ahead were never seen.

Stage 2 (the subtler bug this version fixes): the stage-1 fix advanced
the cursor to the newest message *including the bot's own [ongo]
sends*. A user message timestamped BEFORE one of the bot's sends but
AFTER the previous cursor was then excluded by the `> cursor` filter on
the next poll — silently missed, because the bot "spoke later."

THE INVARIANT
-------------
The user-message gate must be `LAST_USER_TS` = ts of the most recent
USER message actually processed. It advances ONLY when a user message
is handled, and NEVER because the bot sent something. Bot/loop traffic
is irrelevant to whether a user message is outstanding. Detection keys
off LAST_USER_TS exclusively; there is no bot-contaminated cursor.

Robustness: union three independent reads so a single capped/missed
response can't hide a message — `recent` (latest-N head), a numeric
`--since` window (clacks relative strings like "2 hours ago" silently
return nothing — only epoch works), and `--after LAST_USER_TS`. Then
filter to user messages with ts > LAST_USER_TS.
"""
import json
import subprocess
import sys
import time

WINDOW_SECONDS = 21600  # 6h numeric --since safety window
LIM = "400"


def _run(args):
    try:
        out = subprocess.run(["clacks"] + args, capture_output=True,
                              text=True, timeout=60).stdout
        return json.loads(out).get("messages", [])
    except Exception:
        return []


def poll(channel, last_user_ts):
    seen = {}
    # 1. Latest-N head (proper primitive for "most recent messages").
    for m in _run(["recent", "-c", channel, "-l", LIM]) \
            or _run(["recent", "-l", LIM]):
        seen[m.get("ts")] = m
    # 2. Numeric-epoch window (relative strings return nothing in clacks).
    since = str(int(time.time()) - WINDOW_SECONDS)
    for m in _run(["read", "-c", channel, "--since", since, "-l", LIM]):
        seen[m.get("ts")] = m
    # 3. Explicit after-the-gate read.
    for m in _run(["read", "-c", channel, "--after", last_user_ts,
                    "-l", LIM]):
        seen[m.get("ts")] = m

    allm = sorted((m for m in seen.values() if m.get("ts")),
                  key=lambda m: m["ts"])

    def is_bot(m):
        return m.get("text", "").lstrip().startswith(("[ongo]", "_[ongo]"))

    users = [m for m in allm
             if not is_bot(m) and m.get("ts", "0") > last_user_ts]
    newest_user = max((m["ts"] for m in users), default=last_user_ts)

    return {
        "total_seen": len(allm),
        "user_count": len(users),
        "newest_user_ts": newest_user,
        "user_messages": [
            {"ts": m["ts"], "text": m.get("text", "")} for m in users
        ],
    }


if __name__ == "__main__":
    if len(sys.argv) != 3:
        sys.stderr.write("usage: ongo-poll <CHANNEL> <LAST_USER_TS>\n")
        sys.exit(2)
    print(json.dumps(poll(sys.argv[1], sys.argv[2])))
