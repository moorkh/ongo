# Periodic ongo-site regeneration — picks up new kendb ongo-web markers and
# topic/relationship edges automatically (no manual regen needed).
# Install alongside ongo-site-regen.service (see that file's header).

[Unit]
Description=Periodic ongo-site regeneration

[Timer]
OnBootSec=3min
OnUnitActiveSec=15min
AccuracySec=30s
Persistent=true

[Install]
WantedBy=timers.target
